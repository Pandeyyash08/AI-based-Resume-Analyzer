server.port=8080

# 1. Database - MongoDB Atlas
# Replace with your actual MongoDB connection string
spring.mongodb.uri=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# 2. Upload Limits
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# 3. AI API - Use environment variables
groq.api.key=${GROQ_API_KEY:your-groq-api-key}
groq.api.url=${GROQ_API_URL:https://api.groq.com/openai/v1/chat/completions}

# 4. Logging
logging.level.org.springframework.data.mongodb=DEBUG
logging.level.com.yash.analyzer=INFO

# 5. Caching Configuration (for Job Recommendations)
spring.cache.type=simple
spring.cache.cache-names=jobsBySkills

# 6. Job Recommendation Service Configuration
recommendation.engine.default-limit=10
recommendation.engine.minimum-score=40.0
recommendation.engine.skill-match-weight=0.6
recommendation.engine.keyword-match-weight=0.25
recommendation.engine.experience-weight=0.15
